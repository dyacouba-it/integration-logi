                "value": [
                  { "options": { "Nouveau": { "color": "blue", "index": 0 } }, "type": "value" },
                  { "options": { "En cours (attribue)": { "color": "orange", "index": 1 } }, "type": "value" },
                  { "options": { "En cours (planifie)": { "color": "yellow", "index": 2 } }, "type": "value" },
                  { "options": { "En attente": { "color": "purple", "index": 3 } }, "type": "value" },
                  { "options": { "Resolu": { "color": "green", "index": 4 } }, "type": "value" },
                  { "options": { "Clos": { "color": "grey", "index": 5 } }, "type": "value" }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 14, "x": 10, "y": 15 },
      "id": 8,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Date creation" }]
      },
      "title": "20 derniers tickets",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "GLPI-MySQL" },
          "format": "table",
          "rawSql": "-- date_creation TIMESTAMP : DATE_FORMAT() fonctionne directement sans FROM_UNIXTIME\nSELECT\n  t.id AS \"ID\",\n  t.name AS \"Titre\",\n  CASE t.status\n    WHEN 1 THEN 'Nouveau'\n    WHEN 2 THEN 'En cours (attribue)'\n    WHEN 3 THEN 'En cours (planifie)'\n    WHEN 4 THEN 'En attente'\n    WHEN 5 THEN 'Resolu'\n    WHEN 6 THEN 'Clos'\n  END AS \"Statut\",\n  CASE t.priority\n    WHEN 1 THEN 'Tres haute'\n    WHEN 2 THEN 'Haute'\n    WHEN 3 THEN 'Moyenne'\n    WHEN 4 THEN 'Basse'\n    WHEN 5 THEN 'Tres basse'\n    WHEN 6 THEN 'Majeure'\n  END AS \"Priorite\",\n  DATE_FORMAT(t.date_creation, '%d/%m/%Y %H:%i') AS \"Date creation\"\nFROM glpi_tickets t\nWHERE t.is_deleted = 0\nORDER BY t.date_creation DESC\nLIMIT 20;",
          "refId": "A"
        }
      ]
    },

