      "title": "Tickets par priorité (Panel libre — vue responsable)",
      "type": "barchart",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "GLPI-PostgreSQL" },
          "format": "table",
          "rawSql": "-- Répartition par priorité — vision critique pour un responsable IT\n-- Permet d'identifier rapidement les tickets urgents en attente\nSELECT\n  CASE t.priority\n    WHEN 1 THEN 'Très haute'\n    WHEN 2 THEN 'Haute'\n    WHEN 3 THEN 'Moyenne'\n    WHEN 4 THEN 'Basse'\n    WHEN 5 THEN 'Très basse'\n    WHEN 6 THEN 'Majeure'\n    ELSE 'Non défini'\n  END AS priorité,\n  COUNT(*) AS nombre\nFROM glpi_tickets t\nWHERE t.is_deleted = 0\n  AND t.status NOT IN (5, 6)\nGROUP BY t.priority\nORDER BY t.priority;",
          "refId": "A"
        }
      ]
    },

