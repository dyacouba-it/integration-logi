        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Tickets créés aujourd'hui",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "GLPI-MySQL" },
          "format": "table",
          "rawSql": "-- date_creation est un TIMESTAMP natif MariaDB — comparaison directe sans conversion\nSELECT COUNT(*) AS \"Aujourd'hui\"\nFROM glpi_tickets\nWHERE DATE(date_creation) = CURDATE()\n  AND is_deleted = 0;",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "mysql", "uid": "GLPI-MySQL" },
      "description": "Total des ordinateurs et périphériques enregistrés dans GLPI",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
