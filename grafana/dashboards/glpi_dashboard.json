      "title": "Évolution des tickets — 30 derniers jours",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "GLPI-PostgreSQL" },
          "format": "time_series",
          "rawSql": "-- to_timestamp() convertit le timestamp Unix GLPI en timestamp PostgreSQL\n-- DATE_TRUNC agrège par jour pour la série temporelle\nSELECT\n  DATE_TRUNC('day', to_timestamp(date_creation)) AS time,\n  COUNT(*) AS \"Tickets créés\"\nFROM glpi_tickets\nWHERE date_creation >= EXTRACT(EPOCH FROM NOW() - INTERVAL '30 days')\n  AND is_deleted = 0\nGROUP BY 1\nORDER BY 1;",
          "refId": "A",
          "timeColumn": "time"
        }
      ]
