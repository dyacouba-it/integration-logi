          "format": "time_series",
          "rawSql": "-- Agrégation mensuelle des tickets créés sur 12 mois glissants\nSELECT\n  DATE_TRUNC('month', to_timestamp(date_creation)) AS time,\n  COUNT(*) AS \"Tickets / mois\"\nFROM glpi_tickets\nWHERE date_creation >= EXTRACT(EPOCH FROM NOW() - INTERVAL '12 months')\n  AND is_deleted = 0\nGROUP BY 1\nORDER BY 1;",
