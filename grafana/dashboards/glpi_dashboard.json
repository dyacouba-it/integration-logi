          "datasource": { "type": "postgres", "uid": "GLPI-PostgreSQL" },
          "format": "table",
          "rawSql": "-- date_creation est un timestamp Unix (entier) dans GLPI\n-- EXTRACT(EPOCH) convertit minuit local en timestamp Unix\nSELECT COUNT(*) AS \"Aujourd'hui\"\nFROM glpi_tickets\nWHERE date_creation >= EXTRACT(EPOCH FROM date_trunc('day', NOW()))\n  AND is_deleted = 0;",
          "refId": "A"
        }
