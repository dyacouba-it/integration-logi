      "title": "Équipements enregistrés",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "GLPI-MySQL" },
          "format": "table",
          "rawSql": "SELECT (\n  (SELECT COUNT(*) FROM glpi_computers WHERE is_deleted = 0)\n  +\n  (SELECT COUNT(*) FROM glpi_peripherals WHERE is_deleted = 0)\n) AS \"Equipements\";",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "mysql", "uid": "GLPI-MySQL" },
