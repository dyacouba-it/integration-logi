        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "title": "Tickets par mois — 12 derniers mois",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "GLPI-MySQL" },
          "format": "time_series",
          "rawSql": "-- UNIX_TIMESTAMP() convertit la date tronquée au mois vers un entier Unix\n-- nécessaire pour l'axe temporel de Grafana timeseries (MySQL datasource)\nSELECT\n  UNIX_TIMESTAMP(DATE_FORMAT(date_creation, '%Y-%m-01')) AS time,\n  COUNT(*) AS \"Tickets par mois\"\nFROM glpi_tickets\nWHERE date_creation >= DATE_SUB(NOW(), INTERVAL 12 MONTH)\n  AND is_deleted = 0\nGROUP BY DATE_FORMAT(date_creation, '%Y-%m-01')\nORDER BY time;",
          "refId": "A"
        }
