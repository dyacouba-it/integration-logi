      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 15 },
      "id": 7,
      "options": {
        "barRadius": 0.1,
        "barWidth": 0.7,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "horizontal",
        "showValue": "auto",
        "stacking": "none",
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 200
      },
      "title": "Top 5 catégories de tickets",
      "type": "barchart",
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "GLPI-MySQL" },
          "format": "table",
          "rawSql": "SELECT\n  COALESCE(cat.completename, 'Sans categorie') AS categorie,\n  COUNT(t.id) AS nombre\nFROM glpi_tickets t\nLEFT JOIN glpi_itilcategories cat ON t.itilcategories_id = cat.id\nWHERE t.is_deleted = 0\nGROUP BY cat.completename\nORDER BY nombre DESC\nLIMIT 5;",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "mysql", "uid": "GLPI-MySQL" },
      "description": "Les 20 tickets les plus récents avec leur statut et priorité",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
