          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 14, "x": 10, "y": 6 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "title": "Évolution des tickets — 30 derniers jours",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "GLPI-MySQL" },
          "format": "time_series",
          "rawSql": "-- UNIX_TIMESTAMP() convertit une DATE vers un entier Unix (secondes depuis epoch)\n-- requis par Grafana timeseries avec datasource MySQL\nSELECT\n  UNIX_TIMESTAMP(DATE(date_creation)) AS time,\n  COUNT(*) AS \"Tickets crees\"\nFROM glpi_tickets\nWHERE date_creation >= DATE_SUB(NOW(), INTERVAL 30 DAY)\n  AND is_deleted = 0\nGROUP BY DATE(date_creation)\nORDER BY time;",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
