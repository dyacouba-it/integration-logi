      "title": "Top 5 catégories de tickets",
      "type": "barchart",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "GLPI-PostgreSQL" },
          "format": "table",
          "rawSql": "-- Jointure avec glpi_itilcategories pour obtenir le nom de catégorie\n-- COALESCE gère les tickets sans catégorie assignée\nSELECT\n  COALESCE(cat.completename, 'Sans catégorie') AS catégorie,\n  COUNT(t.id) AS nombre\nFROM glpi_tickets t\nLEFT JOIN glpi_itilcategories cat ON t.itilcategories_id = cat.id\nWHERE t.is_deleted = 0\nGROUP BY cat.completename\nORDER BY nombre DESC\nLIMIT 5;",
          "refId": "A"
        }
      ]
    },

