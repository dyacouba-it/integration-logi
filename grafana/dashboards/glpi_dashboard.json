    {
      "datasource": { "type": "mysql", "uid": "GLPI-MySQL" },
      "description": "Tickets dont le statut est ouvert (1=Nouveau, 2=En cours attribué, 3=En cours planifié, 4=En attente)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Tickets ouverts",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "GLPI-MySQL" },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS \"Tickets ouverts\"\nFROM glpi_tickets\nWHERE status NOT IN (5, 6)\n  AND is_deleted = 0;",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "mysql", "uid": "GLPI-MySQL" },
      "description": "Tickets créés depuis minuit aujourd'hui",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "orange", "value": 5 },
