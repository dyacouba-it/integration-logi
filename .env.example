# =============================================================================
# Fichier d'exemple — copier en .env et adapter les valeurs
# NE JAMAIS committer le fichier .env dans Git
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_DB=glpi
POSTGRES_USER=glpi_user
POSTGRES_PASSWORD=changeme

# --- GLPI (connexion à PostgreSQL) -------------------------------------------
GLPI_DB_HOST=postgres
GLPI_DB_NAME=glpi
GLPI_DB_USER=glpi_user
GLPI_DB_PASSWORD=changeme

# --- Grafana ------------------------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# --- Prometheus ---------------------------------------------------------------
# Durée de rétention des métriques (ex: 15d, 30d, 1y)
PROMETHEUS_RETENTION=15d
