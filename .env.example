# =============================================================================
# Fichier d'exemple — copier en .env et adapter les valeurs
# NE JAMAIS committer le fichier .env dans Git
# =============================================================================

# --- MariaDB — Base de données principale de GLPI ----------------------------
MARIADB_DATABASE=glpi
MARIADB_USER=glpi_user
MARIADB_PASSWORD=changeme
MARIADB_ROOT_PASSWORD=changeme_root

# --- PostgreSQL — Maintenu dans la stack pour l'exigence TP ------------------
# GLPI utilise MariaDB (voir README). PostgreSQL est présent pour la datasource
# de démonstration dans Grafana et pour satisfaire l'exigence du sujet TP.
POSTGRES_DB=glpi_tp
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=changeme

# --- Grafana ------------------------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme

# --- Prometheus ---------------------------------------------------------------
# Durée de rétention des métriques (ex: 15d, 30d, 1y)
PROMETHEUS_RETENTION=15d
